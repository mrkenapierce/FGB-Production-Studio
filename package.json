{
  "name": "fgb-production-studio",
  "version": "2.5.0",
  "description": "Desktop and automated asset production studio for FGB, FGBars, and EPIC Communities.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable --x64",
    "assets": "node scripts/generate-separated-assets.mjs",
    "assets:legacy": "node scripts/generate-assets.mjs",
    "render:production": "node scripts/render-standard-production-package.mjs",
    "render:captions": "node scripts/render-word-captions.mjs",
    "generate:shorts": "node scripts/generate-produced-shorts.mjs",
    "test:shorts": "node --test test/shorts-generator.test.mjs"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.epiccommunities.fgbproductionstudio",
    "productName": "FGB Production Studio",
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FGB-Production-Studio-${version}-Windows.${ext}"
    }
  }
}
