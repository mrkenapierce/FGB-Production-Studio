{
  "name": "fgb-production-studio",
  "version": "2.2.0",
  "description": "Desktop and automated asset production studio for FGB, FGBars, and EPIC Communities.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable --x64",
    "assets": "node scripts/generate-separated-assets.mjs",
    "assets:legacy": "node scripts/generate-assets.mjs"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.epiccommunities.fgbproductionstudio",
    "productName": "FGB Production Studio",
    "asar": true,
    "asarUnpack": ["node_modules/ffmpeg-static/**"],
    "files": ["main.js", "renderer/**/*", "package.json", "node_modules/**/*"],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "FGB-Production-Studio-${version}-Windows.${ext}"
    }
  }
}
